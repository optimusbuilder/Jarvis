{
  "name": "@jarvis/desktop-agent",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "voice": "tsx src/adk-agent.ts",
    "adk": "tsx src/adk-agent.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test:unit": "vitest run test/app.test.ts test/voice.test.ts test/browserController.test.ts test/systemController.test.ts",
