## Local development environment variables (copy to `.env`)
#
# IMPORTANT:
# - Never commit real secrets.
# - For production, store secrets in GCP Secret Manager and mount into Cloud Run.
#

#########################
# Desktop agent (local)  #
#########################

# Local backend (if running locally):
# AURA_BACKEND_URL="http://127.0.0.1:8080"
#
# Cloud Run backend (when ready):
# AURA_BACKEND_URL="https://<cloud-run-url>"
AURA_BACKEND_URL="http://127.0.0.1:8080"

# Optional auth token shared with backend. Leave empty for local-only testing.
AURA_BACKEND_AUTH_TOKEN=""

# Local STT (whisper.cpp)
WHISPER_CPP_BIN="whisper-cli"
WHISPER_MODEL_PATH=""

#########################
# Backend (local dev)    #
#########################

# Local-first defaults:
# - planner: local heuristic planner (no Vertex calls)
# - tts: stub audio (no ElevenLabs)
AURA_PLANNER_MODE="local"   # local | vertex
AURA_TTS_MODE="stub"        # stub | elevenlabs

# Vertex AI (required only when AURA_PLANNER_MODE=vertex)
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="global"
AURA_GEMINI_MODEL=""

# ElevenLabs (required only when AURA_TTS_MODE=elevenlabs)
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
ELEVENLABS_MODEL_ID=""


curl -X POST -i https://aura-backend-2xghi7fbva-uc.a.run.app/tts \
  -H "Authorization: Bearer oaYTlaHSJsby-y1jFYuEF6N8DwtnuFa5LTg3JMvguJ2pkK8g-phB9T5oK_Z7frhl" \
