{
  "name": "aura",
  "private": true,
  "workspaces": [
    "backend",
    "desktop",
    "extension"
  ],
  "scripts": {
    "dev": "npm -w desktop run dev",
    "dev:desktop": "npm -w desktop run dev",
    "dev:backend": "npm -w backend run dev",
    "dev:all": "node scripts/dev-all.mjs",
    "start": "npm -w backend run start",
    "build": "npm --workspaces run build",
    "build:backend": "npm -w backend run build",
    "test:unit": "npm -w backend run test:unit && npm -w desktop run test:unit",
    "test:contract": "npm -w backend run test:contract",
    "test:phase0": "make test-phase0",
    "ci:phase0": "make ci-phase0",
    "test:phase1:smoke": "node scripts/p1-smoke.mjs",
    "test:phase2:completion": "node scripts/p2-completion.mjs",
    "test:phase2:integration": "node scripts/p2-integration.mjs",
    "test:phase3:unit": "npm -w extension run test",
    "test:phase3:completion": "node scripts/p3-completion.mjs",
    "test": "npm --workspaces run test",
    "lint": "npm --workspaces run lint",
    "typecheck": "npm --workspaces run typecheck"
  },
  "engines": {
    "node": ">=20"
  }
}
