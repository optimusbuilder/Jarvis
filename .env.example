## Local development environment variables (copy to `.env`)
#
# IMPORTANT:
# - Never commit real secrets.
# - For production, store secrets in GCP Secret Manager and mount into Cloud Run.
#

# Desktop agent
AURA_BACKEND_URL=""
AURA_BACKEND_AUTH_TOKEN=""

# Desktop agent (local STT)
WHISPER_CPP_BIN="whisper-cli"
WHISPER_MODEL_PATH=""

# Backend (local dev only; in Cloud Run these come from env + Secret Manager)
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_REGION="us-central1"
AURA_GEMINI_MODEL=""

ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
ELEVENLABS_MODEL_ID=""
